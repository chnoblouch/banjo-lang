use std.memory;

struct Box[T] {
    var data: *T;

    pub func new(value: T) -> Box[T] {
        var data = memory.alloc(meta(T).size) as *T;
        *data = value;
        return Box[T] { data };
    }

    pub func get(mut self) -> *T {
        return self.data;
    }

    pub func __deinit__(self) {
        __builtin_deinit(*self.data);
        memory.free(self.data);
    }
}
