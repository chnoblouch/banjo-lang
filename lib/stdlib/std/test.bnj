use std.{convert.to_repr, protos.Compare};

func assert_eq[T: Compare[T]](ref a: T, ref b: T) {
    assert_eq_msg(a, b, "assertion failed");
}

func assert_eq_msg[T: Compare[T]](ref a: T, ref b: T, message: String) {
    if a != b {
        print(message);
        print(": ");
        print(to_repr(a));
        print(" != ");
        println(to_repr(b));
        exit(1);
    }
}

func assert_ne[T: Compare[T]](ref a: T, ref b: T) {
    assert_ne_msg(a, b, "assertion failed");
}

func assert_ne_msg[T: Compare[T]](ref a: T, ref b: T, message: String) {
    if a == b {
        print(message);
        print(": ");
        print(to_repr(a));
        print(" == ");
        println(to_repr(b));
        exit(1);
    }
}

func fail() {
    print("test failed");
}
