# test:pass "peephole"
# test:section input

struct @Point:
    field i32 @x
    field i32 @y

struct @Circle:
    field i64 @radius
    field @Point @center

func i32 @f():
    %0 = alloca @Circle
    %1 = memberptr @Circle, addr %0, void 1
    %2 = memberptr @Point, addr %1, void 1
    store i32 42, addr %2
    %3 = memberptr @Circle, addr %0, void 1
    %4 = offsetptr addr %3, void 4, u8
    %5 = load i32, addr %4
    ret i32 %5

# test:section output

struct @Point:
    field i32 @x
    field i32 @y

struct @Circle:
    field i64 @radius
    field @Point @center

func i32 @f():
    %0 = alloca @Circle
    %1 = memberptr @Circle, addr %0, void 1
    %2 = memberptr @Point, addr %1, void 1
    store i32 42, addr %2
    %3 = memberptr @Circle, addr %0, void 1
    %4 = offsetptr addr %3, void 4, u8
    ret i32 42
