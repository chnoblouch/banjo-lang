# test:pass "peephole"
# test:section input

func i32 @f():
    %0 = alloca i32
    %1 = alloca f64
    store i32 42, addr %0
    store f64 0.5, addr %1
    %2 = load i32, addr %0
    ret i32 %2

# test:section output

func i32 @f():
    %0 = alloca i32
    %1 = alloca f64
    store i32 42, addr %0
    store f64 0.5, addr %1
    ret i32 42
