# test:pass "peephole"
# test:section input

func i32 @f():
    %0 = alloca i32
    store i32 42, addr %0
    %1 = add i32 4, i32 8
    %2 = load i32, addr %0
    ret i32 %2

# test:section output

func i32 @f():
    %0 = alloca i32
    store i32 42, addr %0
    %1 = add i32 4, i32 8
    ret i32 42
