# test:error 13:18 "integer literal does not fit into any integer type"

func main() {
    var a: u64 = 184467440737095516150;
    var b: u64 = 28446744073709551615;
    var c: u64 = 18446744083709551615;
    var d: u64 = 18446744073709551616;
    var e: u64 = -18446744073709551616;
}

