# test:subtest
# test:output "5,81,-37,"

func main() {
    meta for value in [5, 81, -37] {
        print(value);
        print(',');
    }
}

# test:subtest
# test:output "5,81,-37,"

func main() {
    var array: [i32; 3] = [5, 81, -37];

    meta for value in array {
        print(value);
        print(',');
    }
}


# test:subtest
# test:output "3,true,test,"

func main() {
    meta for value in (3, true, "test") {
        print(value);
        print(',');
    }
}

# test:subtest
# test:output "3,true,test,"

func main() {
    var tuple = (3, true, "test");
    
    meta for value in tuple {
        print(value);
        print(',');
    }
}

# test:subtest
# test:output "3,true,test,;0.5,42,;"

func print_values[T](values: T) {
    meta for value in values {
        print(value);
        print(',');
    }

    print(';');
}

func main() {
    var a = (3, true, "test");
    var b = (0.5, 42);
    
    print_values(a);
    print_values(b);
}
