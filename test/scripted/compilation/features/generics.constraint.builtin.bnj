# test:subtest
# test:output "40,40,40,40,40,40,40,40,40,"

use std.protos.Shl;

func bit_shl[T: Shl[T]](a: T, b: T) {
    print_number(a << b);
    print(',');
}

func main() {
    bit_shl[i8](5, 3);
    bit_shl[i16](5, 3);
    bit_shl[i32](5, 3);
    bit_shl[i64](5, 3);
    bit_shl[u8](5, 3);
    bit_shl[u16](5, 3);
    bit_shl[u32](5, 3);
    bit_shl[u64](5, 3);
    bit_shl[usize](5, 3);
}

# test:subtest
# test:output "4,4,4,4,4,4,4,4,4,"

use std.protos.Shr;

func bit_shr[T: Shr[T]](a: T, b: T) {
    print_number(a >> b);
    print(',');
}

func main() {
    bit_shr[i8](32, 3);
    bit_shr[i16](32, 3);
    bit_shr[i32](32, 3);
    bit_shr[i64](32, 3);
    bit_shr[u8](32, 3);
    bit_shr[u16](32, 3);
    bit_shr[u32](32, 3);
    bit_shr[u64](32, 3);
    bit_shr[usize](32, 3);
}
