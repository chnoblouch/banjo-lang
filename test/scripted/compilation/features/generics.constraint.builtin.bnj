# TODO: Negative tests

# test:common

# TODO: Remove once a `char` primitive is introduced.
func print_number[T](value: T) {
    if T == u8 {
        print(value as u32);
    } else {
        print(value);
    }
}

# test:subtest
# test:output "eeeeeeeeeeeeeee"

use std.protos.Compare;

func compare[T: Compare[T]](a: T, b: T) {
    if a == b {
        print("e");
    } else {
        print("n");
    }
}

func main() {
    compare[i8](42, 42);
    compare[i16](42, 42);
    compare[i32](42, 42);
    compare[i64](42, 42);
    compare[u8](42, 42);
    compare[u16](42, 42);
    compare[u32](42, 42);
    compare[u64](42, 42);
    compare[usize](42, 42);
    compare[f32](42.0, 42.0);
    compare[f64](42.0, 42.0);
    compare[bool](true, true);
    compare[addr](null, null);

    var a: i32 = 0;

    compare[*i32](&a, &a);
    compare[*Array[i32]](null, null);
}

# test:subtest
# test:output "ggggggggggg"

use std.protos.Order;

func order[T: Order[T]](a: T, b: T) {
    if a > b {
        print("g");
    } else {
        print("l");
    }
}

func main() {
    order[i8](42, 0);
    order[i16](42, 0);
    order[i32](42, 0);
    order[i64](42, 0);
    order[u8](42, 0);
    order[u16](42, 0);
    order[u32](42, 0);
    order[u64](42, 0);
    order[usize](42, 0);
    order[f32](42.0, 0.0);
    order[f64](42.0, 0.0);
}

# test:subtest
# test:output "15,15,15,15,15,15,15,15,15,4.5,4.5,"

use std.protos.Add;

func add[T: Add[T]](a: T, b: T) {
    print_number(a + b);
    print(',');
}

func main() {
    add[i8](12, 3);
    add[i16](12, 3);
    add[i32](12, 3);
    add[i64](12, 3);
    add[u8](12, 3);
    add[u16](12, 3);
    add[u32](12, 3);
    add[u64](12, 3);
    add[usize](12, 3);
    add[f32](4.0, 0.5);
    add[f64](4.0, 0.5);
}

# test:subtest
# test:output "9,9,9,9,9,9,9,9,9,3.5,3.5,"

use std.protos.Sub;

func sub[T: Sub[T]](a: T, b: T) {
    print_number(a - b);
    print(',');
}

func main() {
    sub[i8](12, 3);
    sub[i16](12, 3);
    sub[i32](12, 3);
    sub[i64](12, 3);
    sub[u8](12, 3);
    sub[u16](12, 3);
    sub[u32](12, 3);
    sub[u64](12, 3);
    sub[usize](12, 3);
    sub[f32](4.0, 0.5);
    sub[f64](4.0, 0.5);
}

