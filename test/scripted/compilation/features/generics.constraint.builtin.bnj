    mul[i32](12, 3);
    mul[i64](12, 3);
    mul[u8](12, 3);
    mul[u16](12, 3);
    mul[u32](12, 3);
    mul[u64](12, 3);
    mul[usize](12, 3);
    mul[f32](4.0, 0.5);
    mul[f64](4.0, 0.5);
}

