    print(',');
    print(bit_xor(0x35 as i64, 0x1F as i64));
    print(',');
    print(bit_xor(0x35 as u8, 0x1F as u8) as u32);  # TODO: In the future, `u8` won't be printed as chars anymore.
    print(',');
    print(bit_xor(0x35 as u16, 0x1F as u16));
    print(',');
    print(bit_xor(0x35 as u32, 0x1F as u32));
    print(',');
    print(bit_xor(0x35 as u64, 0x1F as u64));
    print(',');
    print(bit_xor(0x35 as usize, 0x1F as usize));
}

