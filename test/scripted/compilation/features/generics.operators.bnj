    print(',');
    print(shl(21 as i64, 1 as i64));
    print(',');
    print(shl(21 as u8, 1 as u8) as u32);  # TODO: In the future, `u8` won't be printed as chars anymore.
    print(',');
    print(shl(21 as u16, 1 as u16));
    print(',');
    print(shl(21 as u32, 1 as u32));
    print(',');
    print(shl(21 as u64, 1 as u64));
    print(',');
    print(shl(21 as usize, 1 as usize));
}

