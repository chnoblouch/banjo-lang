# test:subtest
# test:output "42,42,42,42,42,42,42,42,42"

func bit_and[T: BitAnd[T]](a: T, b: T) -> T {
    return a & b;
}

func main() {
    print(bit_and(0x3A as i8, 0x2F as i8));
    print(',');
    print(bit_and(0x3A as i16, 0x2F as i16));
    print(',');
    print(bit_and(0x3A as i32, 0x2F as i32));
    print(',');
    print(bit_and(0x3A as i64, 0x2F as i64));
    print(',');
    print(bit_and(0x3A as u8, 0x2F as u8) as u32);  # TODO: In the future, `u8` won't be printed as chars anymore.
    print(',');
    print(bit_and(0x3A as u16, 0x2F as u16));
    print(',');
    print(bit_and(0x3A as u32, 0x2F as u32));
    print(',');
    print(bit_and(0x3A as u64, 0x2F as u64));
    print(',');
    print(bit_and(0x3A as usize, 0x2F as usize));
}

