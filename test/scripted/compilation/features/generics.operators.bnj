# test:subtest
# test:output "e,e,n"

struct IntWrapper: Compare[IntWrapper] {
    var value: i32;

    pub func __eq__(self, ref other: IntWrapper) -> bool {
        return self.value == other.value;
    }

    pub func __ne__(self, ref other: IntWrapper) -> bool {
        return self.value != other.value;
    }
}

pub func test[T: Compare[T]](a: T, b: T) {
    if a == b {
        print('e');
    }

    if a != b {
        print('n');
    }
}

func main() {
    var a = IntWrapper { value: 0 };
    var b = IntWrapper { value: 42 };

    test(a, a);
    print(',');
    test(b, b);
    print(',');
    test(a, b);
}

# test:subtest
# test:output "ltle,gtge,gele"

struct IntWrapper: Order[IntWrapper] {
    var value: i32;

    pub func __gt__(self, ref other: IntWrapper) -> bool {
        return self.value > other.value;
    }

    pub func __lt__(self, ref other: IntWrapper) -> bool {
        return self.value < other.value;
    }

    pub func __ge__(self, ref other: IntWrapper) -> bool {
        return self.value >= other.value;
    }

    pub func __le__(self, ref other: IntWrapper) -> bool {
        return self.value <= other.value;
    }
}

pub func test[T: Order[T]](a: T, b: T) {
    if a > b {
        print("gt");
    }

    if a < b {
        print("lt");
    }

    if a >= b {
        print("ge");
    }

    if a <= b {
        print("le");
    }
}

func main() {
    var a = IntWrapper { value: 0 };
    var b = IntWrapper { value: 42 };

    test(a, b);
    print(',');
    test(b, a);
    print(',');
    test(a, a);
}

# test:subtest
# test:output "29,23,78,8,2,2,27,25,208,3"

struct IntWrapper:
    Add[IntWrapper],
    Sub[IntWrapper],
    Mul[IntWrapper],
    Div[IntWrapper],
    Mod[IntWrapper],
    BitAnd[IntWrapper],
    BitOr[IntWrapper],
    BitXor[IntWrapper],
    Shl[IntWrapper],
    Shr[IntWrapper],
{
    var value: i32;

    pub func __add__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value + other.value };
    }

    pub func __sub__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value - other.value };
    }

    pub func __mul__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value * other.value };
    }

    pub func __div__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value / other.value };
    }

    pub func __mod__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value % other.value };
    }

    pub func __bitand__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value & other.value };
    }

    pub func __bitor__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value | other.value };
    }

    pub func __bitxor__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value ^ other.value };
    }

    pub func __shl__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value << other.value };
    }

    pub func __shr__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value >> other.value };
    }
}

func main() {
    var a = IntWrapper { value: 26 };
    var b = IntWrapper { value: 3 };

    print((a + b).value);
    print(',');
    print((a - b).value);
    print(',');
    print((a * b).value);
    print(',');
    print((a / b).value);
    print(',');
    print((a % b).value);
    print(',');
    print((a & b).value);
    print(',');
    print((a | b).value);
    print(',');
    print((a ^ b).value);
    print(',');
    print((a << b).value);
    print(',');
    print((a >> b).value);
}

# test:subtest
# test:output "11,3,7.5"

func add_max[T: Add[T] + Order[T]](a: T, b: T, addend: T) -> T {
    if a > b {
        return a + addend;
    } else {
        return b + addend;
    }
}

func main() {
    print(add_max(5, 8, 3));
    print(',');
    print(add_max(-3, -10, 6));
    print(',');
    print(add_max(4.0, 2.5, 3.5));
}

# test:subtest
# test:output "11,3"

struct IntWrapper: Add[IntWrapper], Order[IntWrapper] {
    var value: i32;

    pub func __add__(self, ref other: IntWrapper) -> IntWrapper {
        return IntWrapper { value: self.value + other.value };
    }

    pub func __gt__(self, ref other: IntWrapper) -> bool {
        return self.value > other.value;
    }

    pub func __lt__(self, ref other: IntWrapper) -> bool {
        return self.value < other.value;
    }

    pub func __ge__(self, ref other: IntWrapper) -> bool {
        return self.value >= other.value;
    }

    pub func __le__(self, ref other: IntWrapper) -> bool {
        return self.value <= other.value;
    }
}

func add_max[T: Add[T] + Order[T]](a: T, b: T, addend: T) -> T {
    if a > b {
        return a + addend;
    } else {
        return b + addend;
    }
}

func main() {
    var a = IntWrapper { value: 5 };
    var b = IntWrapper { value: 8 };
    var c = IntWrapper { value: 3 };
    var d = IntWrapper { value: -3 };
    var e = IntWrapper { value: -10 };
    var f = IntWrapper { value: 6 };
    
    print(add_max(a, b, c).value);
    print(',');
    print(add_max(d, e, f).value);
}
