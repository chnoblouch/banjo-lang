    print(',');
    print(bit_or(0x28 as i64, 0x02 as i64));
    print(',');
    print(bit_or(0x28 as u8, 0x02 as u8) as u32);  # TODO: In the future, `u8` won't be printed as chars anymore.
    print(',');
    print(bit_or(0x28 as u16, 0x02 as u16));
    print(',');
    print(bit_or(0x28 as u32, 0x02 as u32));
    print(',');
    print(bit_or(0x28 as u64, 0x02 as u64));
    print(',');
    print(bit_or(0x28 as usize, 0x02 as usize));
}

