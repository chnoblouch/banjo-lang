# test:subtest
# test:output "42,42,42,42,42,42,42,42,42,4.25,4.25"

func add[T: Add[T]](a: T, b: T) -> T {
    return a + b;
}

func main() {
    print(add(27 as i8, 15 as i8));
    print(',');
    print(add(27 as i16, 15 as i16));
    print(',');
    print(add(27 as i32, 15 as i32));
    print(',');
    print(add(27 as i64, 15 as i64));
    print(',');
    print(add(27 as u8, 15 as u8) as u32);  # TODO: In the future, `u8` won't be printed as chars anymore.
    print(',');
    print(add(27 as u16, 15 as u16));
    print(',');
    print(add(27 as u32, 15 as u32));
    print(',');
    print(add(27 as u64, 15 as u64));
    print(',');
    print(add(27 as usize, 15 as usize));
    print(',');
    print(add(0.25 as f32, 4.0 as f32));
    print(',');
    print(add(0.25 as f64, 4.0 as f64));
}

# test:subtest
# test:output "42,42,42,42,42,42,42,42,42,4.25,4.25"

func sub[T: Sub[T]](a: T, b: T) -> T {
    return a - b;
}

func main() {
    print(sub(93 as i8, 51 as i8));
    print(',');
    print(sub(93 as i16, 51 as i16));
    print(',');
    print(sub(93 as i32, 51 as i32));
    print(',');
    print(sub(93 as i64, 51 as i64));
    print(',');
    print(sub(93 as u8, 51 as u8) as u32);  # TODO: In the future, `u8` won't be printed as chars anymore.
    print(',');
    print(sub(93 as u16, 51 as u16));
    print(',');
    print(sub(93 as u32, 51 as u32));
    print(',');
    print(sub(93 as u64, 51 as u64));
    print(',');
    print(sub(93 as usize, 51 as usize));
    print(',');
    print(sub(8.0 as f32, 3.75 as f32));
    print(',');
    print(sub(8.0 as f64, 3.75 as f64));
}

