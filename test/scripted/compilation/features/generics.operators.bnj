# test:subtest
# test:output "true,true,true,true,true,true,true,true,true,true,true;false,true"

func le[T: Order[T]](a: T, b: T) -> bool {
    return a <= b;
}

func main() {
    print(le(0 as i8, 1 as i8));
    print(',');
    print(le(0 as i16, 1 as i16));
    print(',');
    print(le(0 as i32, 1 as i32));
    print(',');
    print(le(0 as i64, 1 as i64));
    print(',');
    print(le(0 as u8, 1 as u8));
    print(',');
    print(le(0 as u16, 1 as u16));
    print(',');
    print(le(0 as u32, 1 as u32));
    print(',');
    print(le(0 as u64, 1 as u64));
    print(',');
    print(le(0 as usize, 1 as usize));
    print(',');
    print(le(0.0 as f32, 1.0 as f32));
    print(',');
    print(le(0.0 as f64, 1.0 as f64));
    print(';');
    print(le(1, 0));
    print(',');
    print(le(0, 0));
}

# test:subtest
# test:output "e,e,n"

struct IntWrapper: Compare[IntWrapper] {
    var value: i32;

    pub func __eq__(self, ref other: IntWrapper) -> bool {
        return self.value == other.value;
    }

    pub func __ne__(self, ref other: IntWrapper) -> bool {
        return self.value != other.value;
    }
}

pub func test[T: Compare[T]](a: T, b: T) {
    if a == b {
        print('e');
    }

    if a != b {
        print('n');
    }
}

func main() {
    var a = IntWrapper { value: 0 };
    var b = IntWrapper { value: 42 };

    test(a, a);
    print(',');
    test(b, b);
    print(',');
    test(a, b);
}

# test:subtest
# test:output "ltle,gtge,gele"

struct IntWrapper: Order[IntWrapper] {
    var value: i32;

    pub func __gt__(self, ref other: IntWrapper) -> bool {
        return self.value > other.value;
    }

    pub func __lt__(self, ref other: IntWrapper) -> bool {
        return self.value < other.value;
    }

    pub func __ge__(self, ref other: IntWrapper) -> bool {
        return self.value >= other.value;
    }

    pub func __le__(self, ref other: IntWrapper) -> bool {
        return self.value <= other.value;
    }
}

pub func test[T: Order[T]](a: T, b: T) {
    if a > b {
        print("gt");
    }

    if a < b {
        print("lt");
    }

    if a >= b {
        print("ge");
    }

    if a <= b {
        print("le");
    }
}

func main() {
    var a = IntWrapper { value: 0 };
    var b = IntWrapper { value: 42 };

    test(a, b);
    print(',');
    test(b, a);
    print(',');
    test(a, a);
}
