# test:subtest
# test:output "0,1,2,3"

func type_id[T]() -> u32 {
    if T == i32 {
        return 0;
    } else if T == f32 {
        return 1;
    } else if T == bool {
        return 2;
    } else {
        return 3;
    }
}

func main() {
    print(type_id[i32]());
    print(',');
    print(type_id[f32]());
    print(',');
    print(type_id[bool]());
    print(',');
    print(type_id[u8]());
}

# test:subtest
# test:output "42,0,1"

func type_id[T](override: u32) -> u32 {
    if override != 0 {
        return override;
    } else if T == i32 {
        return 0;
    } else {
        return 1;
    }
}

func main() {
    print(type_id[f32](42));
    print(',');
    print(type_id[i32](0));
    print(',');
    print(type_id[u8](0));
}

# test:subtest
# test:output "0,0,42,1"

func type_id[T](fallback: u32) -> u32 {
    if T == i32 {
        return 0;
    } else if fallback != 0 {
        return fallback;
    } else {
        return 1;
    }
}

func main() {
    print(type_id[i32](0));
    print(',');
    print(type_id[i32](42));
    print(',');
    print(type_id[u8](42));
    print(',');
    print(type_id[u8](0));
}

# test:subtest
# test:output "true,false;false,true;false,false"

func check_type[T]() {
    print(T == i32);
    print(',');
    print(T == f32);
}

func main() {
    check_type[i32]();
    print(';');
    check_type[f32]();
    print(';');
    check_type[bool]();
}
