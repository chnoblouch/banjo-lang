# TODO: Unnecessary casts from u8 to u32

# test:output "6,4,6,4"

func main() {
    var a: u8 = 42;
    var b: u8 = 24;
    var c: i8 = 42;
    var d: i8 = 24;
    
    print((a / 7) as u32);
    print(',');
    print((b / 5) as u32);
    print(',');
    print(c / 7);
    print(',');
    print(d / 5);
}
